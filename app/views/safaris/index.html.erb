<div class="min-h-screen bg-stone-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-8">
      <div class="mb-6 lg:mb-0">
        <h1 class="text-3xl font-extrabold text-stone-900 sm:text-4xl">Wildlife Safaris</h1>
        <p class="mt-2 text-lg text-stone-600">Manage all safari packages and adventures</p>
      </div>

      <% if admin_user? %>
        <%= link_to new_safari_path, 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" do %>
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          New Safari
        <% end %>
      <% end %>
    </div>

    <!-- Safari Grid -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      <% @safaris.each do |safari| %>
        <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 border border-stone-200">
          <!-- Image Section -->
          <div class="relative">
            <% if safari.main_image.attached? %>
              <%= image_tag safari.main_image, 
                  class: "w-full h-48 object-cover",
                  alt: safari.main_image_alt.presence || safari.title %>
            <% else %>
              <div class="w-full h-48 bg-stone-200 flex items-center justify-center">
                <svg class="h-12 w-12 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                </svg>
              </div>
            <% end %>
            
            <!-- Status Badge -->
            <div class="absolute top-4 left-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                <%= safari.status.presence || 'active' %>
              </span>
            </div>
            
            <!-- Featured Badge -->
            <% if safari.is_featured? %>
              <div class="absolute top-4 right-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-200">
                  <svg class="h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                  Featured
                </span>
              </div>
            <% end %>
          </div>

          <!-- Content Section -->
          <div class="p-6">
            <!-- Title and Duration -->
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-bold text-stone-900"><%= safari.title %></h3>
              <span class="text-sm font-medium text-stone-600 bg-stone-100 px-2 py-1 rounded-md">
                <%= pluralize(safari.duration, 'day') %>
              </span>
            </div>

            <!-- Difficulty -->
            <div class="mb-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium 
                <%= safari.difficulty == 'easy' ? 'bg-green-100 text-green-800 border border-green-200' : 
                    safari.difficulty == 'moderate' ? 'bg-orange-100 text-orange-800 border border-orange-200' : 
                    'bg-red-100 text-red-800 border border-red-200' %>">
                <%= safari.difficulty.capitalize %>
              </span>
            </div>

            <!-- Overview -->
            <p class="text-stone-600 mb-4 leading-relaxed"><%= safari.overview_description %></p>

            <!-- Main Attractions -->
            <% if safari.main_attractions.present? %>
              <div class="mb-4">
                <h4 class="text-sm font-semibold text-stone-900 mb-2">Main Attractions:</h4>
                <p class="text-sm text-stone-600"><%= safari.main_attractions %></p>
              </div>
            <% end %>

            <!-- Price and Season -->
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div class="text-center p-3 bg-stone-50 rounded-lg border border-stone-200">
                <p class="text-xs text-stone-500 mb-1">From</p>
                <p class="text-lg font-bold text-green-600">$<%= number_with_delimiter(safari.price_per_person.to_i) %></p>
                <p class="text-xs text-stone-500">per person</p>
              </div>
              <div class="text-center p-3 bg-stone-50 rounded-lg border border-stone-200">
                <p class="text-xs text-stone-500 mb-1">Best Season</p>
                <p class="text-sm font-medium text-stone-700"><%= safari.best_season %></p>
              </div>
            </div>

            <!-- Group Size -->
            <div class="flex items-center text-sm text-stone-600 mb-6">
              <svg class="h-4 w-4 mr-2 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <%= safari.min_people %>-<%= safari.max_people %> people
            </div>

            <!-- Actions -->
            <div class="flex space-x-3 pt-4 border-t border-stone-200">
              <%= link_to 'View', safari, 
                  class: "flex-1 text-center px-4 py-2 text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 rounded-md transition-colors duration-200" %>
              <% if admin_user? %>
                <%= link_to 'Edit', edit_safari_path(safari), 
                    class: "flex-1 text-center px-4 py-2 text-sm font-medium text-stone-700 bg-stone-100 hover:bg-stone-200 rounded-md transition-colors duration-200" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Empty State -->
    <% if @safaris.empty? %>
      <div class="text-center py-16">
        <div class="max-w-md mx-auto">
          <svg class="mx-auto h-16 w-16 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
          </svg>
          <h3 class="mt-4 text-xl font-medium text-stone-900">No safaris yet</h3>
          <p class="mt-2 text-stone-600">Get started by creating your first safari package</p>
          <% if admin_user? %>
            <div class="mt-6">
              <%= link_to new_safari_path, 
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" do %>
                <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Create Safari
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>