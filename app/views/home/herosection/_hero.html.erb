<% if @hero %>
  <!-- Hero Section -->
 <%= render 'home/herosection/heropart', hero: @hero %>
<% else %>
  <!-- Empty State -->
  <div class="relative h-screen min-h-[32rem] bg-gray-900 flex items-center justify-center">
    <div class="text-center max-w-2xl px-4">
      <h2 class="text-3xl font-bold text-white">No hero section configured</h2>
      <p class="mt-4 text-lg text-gray-300">Get started by creating your travel hero section</p>
      <% if user_signed_in? %>
      <%= link_to "Create Hero Section", new_hero_path, class: "mt-6 inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-green-800 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-800" %>
   <% end %>
      </div>
  </div>
<% end %>