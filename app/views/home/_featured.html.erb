<section id="featured-tours" class="py-16 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-stone-900 sm:text-4xl">
        <span class="block">Our Featured Adventures</span>
        <span class="block text-orange-600 mt-2">Handpicked Experiences</span>
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-stone-700">
        Discover our most popular tours loved by travelers worldwide
      </p>
    </div>

    <% if @featured_tours.any? %>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <% @featured_tours.each do |tour| %>
          <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:scale-105 border border-stone-200">
            <% if tour.image.attached? %>
              <div class="h-48 overflow-hidden">
                <%= image_tag tour.image, class: "w-full h-full object-cover transition-transform duration-300 hover:scale-110", alt: tour.name %>
              </div>
            <% else %>
              <div class="h-48 bg-stone-100 flex items-center justify-center">
                <span class="text-stone-500">No image available</span>
              </div>
            <% end %>
            
            <div class="p-6">
              <div class="flex items-center mb-3">
                <span class="inline-block px-3 py-1 text-xs font-semibold text-green-800 bg-green-100 rounded-full border border-green-200">
                  <%= tour.category %>
                </span>
                <span class="ml-auto text-sm font-medium text-stone-600 bg-stone-100 px-2 py-1 rounded-md">
                  <%= tour.duration %> days
                </span>
              </div>
              
              <h3 class="text-xl font-bold text-stone-900 mb-3"><%= tour.name %></h3>
              <p class="text-stone-600 mb-4 leading-relaxed"><%= truncate(tour.description, length: 100) %></p>
              
              <div class="flex items-center justify-between pt-4 border-t border-stone-200">
                <span class="text-2xl font-bold text-green-600">$<%= tour.price %></span>
                <%= link_to "View Tour", travel_tour_path(tour), 
                    class: "px-4 py-2 text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 rounded-md transition-colors duration-200 shadow-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-12 text-center">
        <%= link_to "View All Tours", travel_tours_path, 
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="max-w-md mx-auto">
          <svg class="mx-auto h-16 w-16 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="mt-4 text-lg text-stone-600 mb-6">No featured tours available yet</p>
          <% if user_signed_in? %>
            <%= link_to "Create a Tour", new_travel_tour_path, 
                class: "px-6 py-3 bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors duration-200 font-medium" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>