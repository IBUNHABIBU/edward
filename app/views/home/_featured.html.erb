<section id="featured-tours" class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
        <span class="block">Our Featured Adventures</span>
        <span class="block text-amber-600 mt-2">Handpicked Experiences</span>
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-600">
        Discover our most popular tours loved by travelers worldwide
      </p>
    </div>

    <% if @featured_tours.any? %>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <% @featured_tours.each do |tour| %>
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300">
            <% if tour.image.attached? %>
              <div class="h-48 overflow-hidden">
                <%= image_tag tour.image, class: "w-full h-full object-cover", alt: tour.name %>
              </div>
            <% else %>
              <div class="h-48 bg-gray-200 flex items-center justify-center">
                <span class="text-gray-500">No image available</span>
              </div>
            <% end %>
            <div class="p-6">
              <div class="flex items-center mb-2">
                <span class="inline-block px-2 py-1 text-xs font-semibold text-amber-800 bg-amber-100 rounded-full"><%= tour.category %></span>
                <span class="ml-auto text-sm font-medium text-green-800"><%= tour.duration %> days</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2"><%= tour.name %></h3>
              <p class="text-gray-600 mb-4"><%= truncate(tour.description, length: 100) %></p>
              <div class="flex items-center justify-between">
                <span class="text-lg font-bold text-green-800">$<%= tour.price %></span>
                <%= link_to "View Tour", travel_tour_path(tour), class: "px-4 py-2 text-sm font-medium text-white bg-amber-600 hover:bg-amber-700 rounded-md transition" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-12 text-center">
        <%= link_to "View All Tours", travel_tours_path, class: "px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-800 hover:bg-green-700 shadow-sm" %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-500 mb-4">No featured tours available yet</p>
        <% if user_signed_in? %>
          <%= link_to "Create a Tour", new_travel_tour_path, class: "px-4 py-2 bg-green-800 text-white rounded-md hover:bg-green-700" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>