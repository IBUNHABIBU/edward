<section class="py-16 bg-white" id="destinations">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
        Explore Our Top Destinations
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-600">
        From majestic mountains to pristine beaches
      </p>
    </div>

    <% if @popular_destinations.any? %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% @popular_destinations.each do |destination| %>
          <div class="relative group overflow-hidden rounded-lg shadow-md h-96">
            <% if destination.image.attached? %>
              <%= image_tag destination.image, class: "w-full h-full object-cover transform group-hover:scale-105 transition duration-500", alt: destination.name %>
            <% else %>
              <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                <span class="text-gray-500">No image available</span>
              </div>
            <% end %>
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/70 via-gray-900/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6 w-full">
              <h3 class="text-2xl font-bold text-white"><%= destination.name %></h3>
              <p class="mt-2 text-gray-200"><%= destination.country %></p>
              <%= link_to "View destination", destination_path(destination), class: "mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-green-800 bg-amber-300 hover:bg-amber-400" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-500 mb-4">No featured destinations available yet</p>
        <% if user_signed_in? %>
          <%= link_to "Add Destinations", new_destination_path, class: "px-4 py-2 bg-green-800 text-white rounded-md hover:bg-green-700" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>