<section class="py-16 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-stone-900 sm:text-4xl">
        Traveler Stories
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-stone-700">
        Don't just take our word for it
      </p>
    </div>

    <% if @testimonials.any? %>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        <% @testimonials.each do |testimonial| %>
          <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all duration-300 border border-stone-200">
            <!-- Quote Icon -->
            <div class="text-orange-500 mb-4">
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
              </svg>
            </div>

            <!-- Testimonial Content -->
            <p class="text-stone-700 text-lg italic mb-6 leading-relaxed">"<%= testimonial.content %>"</p>

            <!-- Star Rating -->
            <div class="flex items-center mb-4">
              <% 5.times do |i| %>
                <% if i < testimonial.star_rating.to_i %>
                  <svg class="h-5 w-5 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                <% else %>
                  <svg class="h-5 w-5 text-stone-300" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                <% end %>
              <% end %>
              <span class="ml-2 text-sm font-medium text-stone-600"><%= testimonial.star_rating %>/5</span>
            </div>

            <!-- Author Info -->
            <div class="flex items-center">
              <% if testimonial.avatar.attached? %>
                <%= image_tag testimonial.avatar, 
                    class: "h-12 w-12 rounded-full object-cover border-2 border-stone-200", 
                    alt: testimonial.author_name %>
              <% else %>
                <div class="h-12 w-12 rounded-full bg-stone-200 flex items-center justify-center border-2 border-stone-300">
                  <span class="text-stone-500 text-sm font-medium">Photo</span>
                </div>
              <% end %>
              <div class="ml-4">
                <h4 class="text-lg font-semibold text-stone-900"><%= testimonial.author_name %></h4>
                <% if testimonial.author_title.present? %>
                  <p class="text-stone-600 text-sm"><%= testimonial.author_title %></p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-12 text-center">
        <%= link_to "Read More Stories", testimonials_path, 
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="max-w-md mx-auto">
          <svg class="mx-auto h-16 w-16 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          <p class="mt-4 text-lg text-stone-600 mb-6">No testimonials yet</p>
          <%= link_to "Add Testimonial", new_testimonial_path, 
              class: "px-6 py-3 bg-orange-600 text-white rounded-md hover:bg-orange-700 transition-colors duration-200 font-medium" %>
        </div>
      </div>
    <% end %>
  </div>
</section>