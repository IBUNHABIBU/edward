<div class="min-h-screen bg-stone-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex justify-center">
         <div class="flex-shrink-0">
        <%= link_to root_path, class: "flex items-center space-x-2" do %>
          <span class="[-webkit-text-stroke:1px_black]"><%= render 'shared/logo' %></span>
        <% end %>
      </div>
    </div>

    <h2 class="mt-6 text-center text-3xl font-extrabold text-stone-900">
      Sign in to your account
    </h2>
    <p class="mt-2 text-center text-sm text-stone-600">
      Or
      <%= link_to "create a new account", new_user_registration_path, class: "font-medium text-orange-600 hover:text-orange-500 transition-colors duration-200" %>
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-lg sm:rounded-xl sm:px-10 border border-stone-200">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-6">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-2" %>
            <div class="mt-1">
              <%= f.email_field :email, 
                  autofocus: true, 
                  autocomplete: "email",
                  class: "appearance-none block w-full px-3 py-2 border border-stone-300 rounded-md placeholder-stone-400 focus:outline-none focus:ring-orange-500 focus:border-orange-500 transition-colors duration-200",
                  placeholder: "Enter your email" %>
            </div>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-stone-700 mb-2" %>
            <div class="mt-1">
              <%= f.password_field :password, 
                  autocomplete: "current-password",
                  class: "appearance-none block w-full px-3 py-2 border border-stone-300 rounded-md placeholder-stone-400 focus:outline-none focus:ring-orange-500 focus:border-orange-500 transition-colors duration-200",
                  placeholder: "Enter your password" %>
            </div>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "h-4 w-4 text-orange-600 focus:ring-orange-500 border-stone-300 rounded" %>
              <%= f.label :remember_me, class: "ml-2 block text-sm text-stone-700" %>
            </div>
          <% end %>

          <div>
            <%= f.submit "Sign in", 
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-colors duration-200" %>
          </div>
        </div>
      <% end %>

      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-stone-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-stone-500">Need help?</span>
          </div>
        </div>

        <div class="mt-6 text-center">
          <%= link_to "Forgot your password?", new_password_path(resource_name), 
              class: "font-medium text-stone-600 hover:text-orange-500 transition-colors duration-200" %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Alert Messages -->
<% if alert %>
  <div class="fixed top-4 right-4 max-w-sm w-full bg-red-50 border border-red-200 rounded-lg shadow-lg z-50">
    <div class="flex p-4">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-red-800"><%= alert %></p>
      </div>
    </div>
  </div>
<% end %>

<% if notice %>
  <div class="fixed top-4 right-4 max-w-sm w-full bg-green-50 border border-green-200 rounded-lg shadow-lg z-50">
    <div class="flex p-4">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-green-800"><%= notice %></p>
      </div>
    </div>
  </div>
<% end %>