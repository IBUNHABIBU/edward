<!-- Hero Section -->
<section class="relative py-20 bg-stone-900 overflow-hidden">
  <div class="absolute inset-0">
    <%= image_tag "lions2.jpg", alt: "Team hiking in mountains", class: "w-full h-full object-cover opacity-40" %>
  </div>
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6">
      Our Story
    </h1>
    <p class="text-xl md:text-2xl text-stone-200">
      Crafting unforgettable journeys since 2010
    </p>
  </div>
</section>

<!-- Vision Section -->
<section class="py-16 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-extrabold text-stone-900 mb-6">
          Our Vision
        </h2>
        <p class="text-lg text-stone-700 leading-relaxed">
          To create a world where travel is a transformative force for good—connecting people across cultures, preserving natural wonders, and empowering local communities to thrive through sustainable tourism.
        </p>
      </div>
      <div class="lg:w-1/2">
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <%= image_tag "tembo.jpg", alt: "Inspiring travel vision", class: "w-full h-64 md:h-96 object-cover" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mission Section -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row-reverse items-center gap-12">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-extrabold text-stone-900 mb-6">
          Our Mission
        </h2>
        <p class="text-lg text-stone-700 leading-relaxed">
          To craft authentic, immersive travel experiences that respect local cultures and ecosystems while providing meaningful economic opportunities for communities. We're dedicated to showing travelers the heart and soul of each destination through carefully curated adventures that leave positive impacts.
        </p>
      </div>
      <div class="lg:w-1/2">
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <%= image_tag "twigasingle.jpg", alt: "Our mission in action", class: "w-full h-64 md:h-96 object-cover" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why We Exist Section -->
<section class="py-16 bg-orange-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-extrabold text-stone-900 mb-6">
      Why We Exist
    </h2>
    <p class="text-xl text-stone-700 max-w-3xl mx-auto">
      At Yote Safari, we believe travel should transform lives. Our mission is to connect adventurers with authentic, sustainable experiences that respect local cultures and ecosystems.
    </p>
  </div>
</section>

<!-- Our Journey Section -->
<section class="py-16 bg-stone-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold text-stone-900 text-center mb-12">
      Our Journey
    </h2>
    <div class="flex justify-center">
      <div class="bg-white rounded-xl shadow-lg p-8 max-w-md border border-stone-200">
        <div class="flex items-start space-x-4">
          <div class="flex-shrink-0">
            <div class="h-16 w-16 bg-green-600 rounded-full flex items-center justify-center">
              <span class="text-white font-bold text-lg">2010</span>
            </div>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-stone-900 mb-2">Founded in Arusha</h3>
            <p class="text-stone-600">Started with just 3 local hiking tours and a passion for sharing hidden gems.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Team Section -->
<section id="team" class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold text-stone-900 text-center mb-12">
      Meet Our Guides
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @team_members.each do |member| %>
        <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 border border-stone-200">
          <div class="h-48 overflow-hidden">
            <% if member.photo.attached? %>
              <%= image_tag url_for(member.photo), alt: member.name, class: "w-full h-full object-cover" %>
            <% else %>
              <%= image_tag "mavelogo.png", alt: member.name, class: "w-full h-full object-cover" %>
            <% end %>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2"><%= member.name %></h3>
            <p class="text-green-600 font-semibold mb-3"><%= member.title %></p>
            <p class="text-stone-600"><%= member.bio %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Values Section -->
<section class="py-16 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold text-stone-900 text-center mb-12">
      Our Core Values
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <% @values.each do |value| %>
        <div class="text-center">
          <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-orange-100 text-orange-600 mb-4">
            <%= value_icon(value[:icon]) %>
          </div>
          <h3 class="text-lg font-semibold text-stone-900 mb-2"><%= value[:title] %></h3>
          <p class="text-stone-600 text-sm"><%= value[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Responsible Tourism Section -->
<section class="py-16 bg-green-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <div class="lg:w-1/2">
        <h2 class="text-3xl font-extrabold text-stone-900 mb-6">
          Responsible Tourism
        </h2>
        <p class="text-lg text-stone-700 leading-relaxed mb-6">
          We're committed to protecting the places we love. We promote travel that respects local cultures, supports communities, and preserves natural environments for future generations.
        </p>
        <%= link_to "Learn more", root_path, 
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" %>
      </div>
      <div class="lg:w-1/2">
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <%= image_tag "comunity.jpg", alt: "Conservation project", class: "w-full h-64 md:h-96 object-cover" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- License Section -->
<div class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-extrabold text-stone-900 mb-6">Our Business License</h2>
    <p class="text-lg text-stone-700 mb-8 max-w-2xl mx-auto">
      We are fully licensed and registered to provide professional safari and trekking services in Tanzania. Here is a copy of our official business license:
    </p>
    <div class="bg-stone-50 rounded-xl p-8 border border-stone-200 max-w-2xl mx-auto">
      # <%=  %>
    </div>
  </div>
</div>

<!-- CTA Section -->
<section class="py-16 bg-stone-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-extrabold text-white mb-8">
      Ready to Explore With Us?
    </h2>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "Meet Our Guides", "#team", 
          class: "px-8 py-3 border-2 border-white text-base font-medium rounded-md text-white hover:bg-white hover:text-stone-900 transition-colors duration-200" %>
      <%= link_to "View Tours", travel_tours_path, 
          class: "px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 shadow-sm transition-colors duration-200" %>
    </div>
  </div>
</section>