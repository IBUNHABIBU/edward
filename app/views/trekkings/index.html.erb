<%= render template: 'gears/index' %>

<div class="min-h-screen bg-stone-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8">
      <h1 class="text-3xl font-extrabold text-stone-900 sm:text-4xl mb-4 sm:mb-0">Treks</h1>
      <% if user_signed_in? %>
        <%= link_to 'New Trek', new_trekking_path, 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" %>
      <% end %>
    </div>

    <!-- Treks List -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-stone-200">
      <ul class="divide-y divide-stone-200">
        <% @trekkings.each do |trekking| %>
          <li class="hover:bg-stone-50 transition-colors duration-150">
            <%= link_to trekking_path(trekking), class: "block p-6" do %>
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <!-- Title and Difficulty -->
                <div class="flex items-center space-x-4 mb-4 sm:mb-0">
                  <div class="flex-shrink-0">
                    <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-lg font-semibold text-stone-900"><%= trekking.title %></p>
                    <div class="mt-1">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                        <%= trekking.difficulty == 'easy' ? 'bg-green-100 text-green-800 border border-green-200' : 
                            trekking.difficulty == 'moderate' ? 'bg-orange-100 text-orange-800 border border-orange-200' : 
                            'bg-red-100 text-red-800 border border-red-200' %>">
                        <%= trekking.difficulty.capitalize %>
                      </span>
                    </div>
                  </div>
                </div>

                <!-- Duration and Calendar -->
                <div class="flex items-center space-x-6 text-sm text-stone-600">
                  <div class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-stone-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                    <%= pluralize(trekking.duration, 'day') %>
                  </div>
                  <div class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-stone-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-stone-700 font-medium">Available</span>
                  </div>
                  
                  <!-- Arrow indicator -->
                  <svg class="h-5 w-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Empty State -->
    <% if @trekkings.empty? %>
      <div class="text-center py-16">
        <div class="max-w-md mx-auto">
          <svg class="mx-auto h-16 w-16 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/>
          </svg>
          <h3 class="mt-4 text-xl font-medium text-stone-900">No treks available</h3>
          <p class="mt-2 text-stone-600">Get started by creating your first trekking adventure</p>
          <% if user_signed_in? %>
            <div class="mt-6">
              <%= link_to 'New Trek', new_trekking_path, 
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition-colors duration-200" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>